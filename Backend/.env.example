NODE_ENV=development
HOST=0.0.0.0
PORT=4000
API_PREFIX=/api
API_VERSION=v1
SHUTDOWN_TIMEOUT_MS=15000

MONGODB_URI=mongodb://127.0.0.1:27017/swing-pool
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_RETRY_ATTEMPTS=5
MONGODB_RETRY_DELAY_MS=1000
MONGODB_RETRY_MAX_DELAY_MS=15000
SKIP_DB_CONNECTION=false

JWT_SECRET=replace-this-with-a-secure-jwt-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace-this-with-a-secure-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
AUTH_EMAIL_VERIFICATION_TOKEN_EXPIRES_IN=24h
AUTH_PASSWORD_RESET_TOKEN_EXPIRES_IN=1h
SUBSCRIPTION_GRACE_PERIOD_DAYS=7
SUBSCRIPTION_MANDATORY_CHARITY_PERCENTAGE=10
CHARITY_DEFAULT_CURRENCY=INR
CHARITY_GATEWAY_FEE_PERCENTAGE=0
CHARITY_PRIZE_POOL_PERCENTAGE=35
CHARITY_MANDATORY_PERCENTAGE=10

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
REQUEST_JSON_LIMIT=1mb
REQUEST_URLENCODED_LIMIT=1mb

LOG_LEVEL=info
# Update to match your frontend dev origin(s) during local integration.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Idempotency-Key,X-Request-Id,Stripe-Signature
TRUST_PROXY=false

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_WEBHOOK_PROCESSING_TIMEOUT_MS=8000
STRIPE_MOCK_MODE=true
PAYMENT_ATTEMPT_TIMEOUT_MINUTES=30
NOTIFICATIONS_EMAIL_PROVIDER=log
NOTIFICATIONS_SMS_PROVIDER=noop
NOTIFICATIONS_FROM_EMAIL=no-reply@swingpool.local
NOTIFICATIONS_FROM_SMS=SWINGPOOL

JOBS_ENABLED=true
JOBS_RENEWAL_REMINDER_INTERVAL_MS=1800000
JOBS_GRACE_PERIOD_CHECK_INTERVAL_MS=1800000
JOBS_EXPIRY_ENFORCEMENT_INTERVAL_MS=1800000
JOBS_MONTHLY_DRAW_PREP_INTERVAL_MS=3600000
JOBS_DRAW_EXECUTION_INTERVAL_MS=3600000
JOBS_WINNER_PROOF_CHECK_INTERVAL_MS=3600000
JOBS_PAYMENT_RECONCILIATION_INTERVAL_MS=900000
JOBS_RENEWAL_REMINDER_LEAD_DAYS=3
JOBS_GRACE_WARNING_LEAD_DAYS=2
JOBS_PAYMENT_RECONCILIATION_LOOKBACK_MINUTES=30
JOBS_PAYMENT_RECONCILIATION_BATCH_SIZE=100

IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_REQUIRED_METHODS=POST,PUT,PATCH

OPENAPI_ENABLED=true
OPENAPI_SERVER_URL=http://localhost:4000/api/v1

TZ=Asia/Kolkata

SEEDS=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_ROTATE_EMAIL=
ADMIN_ROTATE_PASSWORD=
SAMPLE_SEED_ENABLED=false
SAMPLE_SEED_SOURCE_PATH=

# Local demo users created when SAMPLE_SEED_ENABLED=true
# Prefer keeping demo credentials in a local-only file such as:
# SAMPLE_SEED_SOURCE_PATH=.local/sample-seed.json
