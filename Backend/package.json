{
  "name": "swing-pool",
  "version": "1.0.0",
  "description": "A modern subscription platform where users track golf performance, participate in monthly reward draws, and support charities, all in one seamless experience.",
  "keywords": [
    "golf",
    "play",
    "backend",
    "pool",
    "charity",
    "swing"
  ],
  "license": "ISC",
  "author": "Kaushik",
  "type": "module",
  "main": "src/server/index.js",
  "scripts": {
    "dev": "nodemon --watch src src/server/index.js",
    "start": "node src/server/index.js",
    "start:prod": "NODE_ENV=production node src/server/index.js",
    "build": "npm run lint && npm run typecheck && npm run test && npm run openapi:check && npm run postman:generate",
    "seed": "node src/database/seeds/run-seeds.js",
    "rotate:admin-password": "node src/database/seeds/rotate-admin-password.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "typecheck": "node scripts/typecheck.mjs",
    "openapi:check": "node scripts/check-openapi.mjs",
    "openapi:export": "node scripts/export-openapi.mjs",
    "postman:generate": "node scripts/generate-postman-collection.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^22.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  }
}
